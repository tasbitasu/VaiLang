{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build VaiLang Compiler (vai)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-g",
                "-Iinclude",
                "src/main.cpp",
                "src/lexer/lexer.cpp",
                "src/parser/parser.cpp",
                "src/codegen/generator.cpp",
                "-o",
                "vai"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
